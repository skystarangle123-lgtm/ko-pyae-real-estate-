// ── Local rule-based classifier (no API key needed, works offline) ──
function burmeseToArabic(str){
  const map={'၀':'0','၁':'1','၂':'2','၃':'3','၄':'4','၅':'5','၆':'6','၇':'7','၈':'8','၉':'9'};
  return str.replace(/[၀-၉]/g, d=>map[d]);
}

function extractPhone(text){
  const norm=burmeseToArabic(text);
  // Match patterns like 09-123 456 789, 09123456789, 09 789 782 619
  const m=norm.match(/0?9[\d\s\-]{7,12}\d/);
  if(!m) return null;
  const digits=m[0].replace(/[\s\-]/g,'');
  const d=digits.startsWith('9')?'0'+digits:digits;
  // format as 09-XXXXXXXXX
  return d.length>=9 ? '09-'+d.slice(2) : d;
}

function extractPrice(text){
  const norm=burmeseToArabic(text);
  // e.g. "350,000,000", "70 သိန်း", "650M", "500 lakhs", "3.5 သိန်း"
  let m=norm.match(/([\d,]+(\.\d+)?)\s*(သိန်း|lakh|lakhs|laks)/i);
  if(m) return m[1].replace(/,/g,'')+' Lakhs';
  m=norm.match(/([\d,]+(\.\d+)?)\s*(M|million)/i);
  if(m) return m[1].replace(/,/g,'')+'M';
  m=norm.match(/Ks\.?\s*([\d,]+)/i);
  if(m) return 'Ks '+m[1];
  m=norm.match(/\b\d{2,3}(,\d{3}){2,}\b/);
  if(m) return 'Ks '+m[0];
  return null;
}

function extractTownship(text){
  const townships=['ဗဟန်း','ကမာရွတ်','ယန်ကင်း','Yankin','သာကေတ','ကံကော','မြောက်ဒဂုံ','စမ်းချောင်း',
    'Sanchaung','Kamayut','Hlaing','လှိုင်','Tarmwe','တာမွေ','Mingalardon','မင်္ဂလာဒုံ','Insein','အင်းစိန်',
    'Inya','အင်းလျား','Kyauktada','ကျောက်တံတား','South Okkalapa','ရွှေပြည်သာ','Thaketa','သင်္ဃန်းကျွန်း',
    'Mayangone','မရမ်းကုန်း','Botataung','ဗိုလ်တထောင်','Dagon','ဒဂုံ'];
  for(const t of townships){ if(text.includes(t)) return t; }
  return null;
}

function extractDateTime(text){
  const norm=burmeseToArabic(text);
  let parts=[];
  const dayWords=['today','tomorrow','tonight','ယနေ့','မနက်ဖြန်','today morning'];
  for(const d of dayWords){ if(norm.toLowerCase().includes(d.toLowerCase())) parts.push(d); }
  const time=norm.match(/\d{1,2}(:\d{2})?\s*(am|pm|AM|PM|နာရီ)/);
  if(time) parts.push(time[0]);
  return parts.length? parts.join(' ') : null;
}

async function callAI(userText){
  return new Promise(resolve=>{
    const text=userText.trim();
    const lower=text.toLowerCase();
    const norm=burmeseToArabic(text);

    const phone=extractPhone(text);
    const price=extractPrice(text);
    const township=extractTownship(text);
    const dateTime=extractDateTime(text);

    // ── Keyword scoring ──
    const kw={
      rental:['ငှား','rent','for rent','lease','tenant','PN','လွှာ','monthly','per month','ငှားမယ်','ငှားမည်'],
      sale:['ရောင်း','sale','for sale','sell','selling','ရောင်းမယ်','ရောင်းမည်','ရောင်းရန်','မြေကွက်','land','property for sale'],
      client:['buy','purchase','looking for','want to','budget','ဝယ်','ဝယ်လို','interested','client','customer','wants to buy'],
      schedule:['meeting','appointment','schedule','viewing','visit','tomorrow','today','am','pm','meet','calendar','ချိန်း']
    };
    const scores={rental:0,sale:0,client:0,schedule:0};
    for(const [cat,words] of Object.entries(kw)){
      for(const w of words){
        if(lower.includes(w.toLowerCase()) || text.includes(w)) scores[cat]++;
      }
    }
    // boost: sale + land/property type beats client
    if(scores.sale>0) scores.sale+=1;
    if(/buy|ဝယ်/.test(lower) && scores.rental===0 && scores.sale===0) scores.client+=2;

    let category=Object.entries(scores).sort((a,b)=>b[1]-a[1])[0][0];
    if(Object.values(scores).every(v=>v===0)) category='client';

    const tableMap={rental:'rentals',sale:'sales',client:'clients',schedule:'schedules'};
    const iconMap={rental:'🏠',sale:'🏢',client:'👤',schedule:'📅'};
    const table=tableMap[category];
    const icon=iconMap[category];

    // ── Build fields per category ──
    let fields={};
    let title='';

    if(category==='rental'){
      fields.address = text.length>50? text.slice(0,50)+'…' : text;
      if(township) fields.township=township;
      const floorM=norm.match(/(\d+)\s*(လွှာ|floor|ထပ်)/i);
      if(floorM) fields.floor=floorM[1]+' Floor';
      const bedM=norm.match(/(\d+)\s*(PN|bedroom|bed|အိပ်ခန်း|BR)/i);
      if(bedM) fields.bedrooms=bedM[1]+' BR';
      if(price) fields.monthly_rent=price;
      if(phone) fields.contact=phone;
      title=(township?township+' ':'')+'Rental Listing';
    }
    else if(category==='sale'){
      fields.address = text.length>50? text.slice(0,50)+'…' : text;
      if(township) fields.township=township;
      const sizeM=norm.match(/(\d+)\s*[xX×]\s*(\d+)/);
      if(sizeM) fields.land_size=sizeM[0];
      if(price) fields.price=price;
      const ptypeM=lower.match(/condo|apartment|land|house|office|shop|warehouse|tower/i);
      if(ptypeM) fields.property_type=ptypeM[0];
      if(phone) fields.contact=phone;
      title=(township?township+' ':'')+'For Sale';
    }
    else if(category==='client'){
      const nameM=text.match(/(Daw|U|Ko|Ma|Mg)\s+[A-Za-z\u1000-\u109F]+(\s+[A-Za-z\u1000-\u109F]+)?/);
      if(nameM) fields.name=nameM[0];
      if(phone) fields.phone=phone;
      const purposeM=lower.match(/buy|purchase|rent|looking for [\w\s]+/i);
      if(purposeM) fields.purpose=purposeM[0];
      const budgetM=norm.match(/budget\s*[\d,]+\s*(lakh|lakhs|M|million|သိန်း)?/i) || (price?[price]:null);
      if(budgetM) fields.budget=Array.isArray(budgetM)?budgetM[0]:budgetM[0];
      if(township) fields.preferred_area=township;
      title=(fields.name?fields.name+' — ':'')+'Client Inquiry';
    }
    else { // schedule
      if(dateTime) fields.datetime=dateTime;
      const locM=lower.match(/(office|branch|sanchaung|kamayut|yankin)[\w\s]*/i) || (township?[township]:null);
      if(locM) fields.location=Array.isArray(locM)?locM[0]:locM[0];
      const attM=text.match(/(Daw|U|Ko|Ma|Mg)\s+[A-Za-z\u1000-\u109F]+(\s+[A-Za-z\u1000-\u109F]+)?/);
      if(attM) fields.attendees=attM[0];
      fields.agenda = text.length>60? text.slice(0,60)+'…' : text;
      title='Schedule: '+(dateTime||'Upcoming meeting');
    }

    if(!title) title=text.slice(0,40)+(text.length>40?'…':'');

    const confidence = Math.min(95, 55 + Object.keys(fields).length*8 + (phone?5:0) + (price?5:0));

    const result={
      category, table, icon, title,
      confidence,
      fields,
      normalized_phone: phone,
      summary: `Detected as ${category} record with ${Object.keys(fields).length} field(s) extracted.`
    };

    // simulate small processing delay for UX
    setTimeout(()=>resolve(result), 600);
  });
}

function showResult(r, raw){
  document.getElementById('rIcon').textContent=r.icon||'📋';
  document.getElementById('rTitle').textContent=r.title||'Parsed';
  document.getElementById('rTable').textContent=`→ ${r.table}`;

  const b=document.getElementById('rBadge');
  b.textContent=r.category.toUpperCase();
  b.className=`cat-pill cat-${r.category}`;

  const g=document.getElementById('fieldGrid');
  g.innerHTML='';
  if(r.fields){
    Object.entries(r.fields).filter(([,v])=>v).forEach(([k,v])=>{
      const el=document.createElement('div');
      el.className='field-item';
      el.innerHTML=`<div class="field-k">${k.replace(/_/g,' ')}</div><div class="field-v hi">${v}</div>`;
      g.appendChild(el);
    });
  }
  if(r.summary){
    const s=document.createElement('div');
    s.className='field-item';s.style.gridColumn='1/-1';
    s.innerHTML=`<div class="field-k">AI Summary</div><div class="field-v" style="color:var(--muted-on-dark)">${r.summary}</div>`;
    g.appendChild(s);
  }
  const p=r.confidence||85;
  setTimeout(()=>{
    document.getElementById('confFill').style.width=p+'%';
    document.getElementById('confPct').textContent=p+'%';
  },300);
  document.getElementById('resultCard').classList.add('show');
}

async function confirmStore(){
