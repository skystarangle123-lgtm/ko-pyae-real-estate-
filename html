  log(`✓ Saved → [${pending.table}] "${pending.title}"`, 'ok');
  document.getElementById('resultCard').classList.remove('show');
  document.getElementById('rawInput').value='';
  pending=null;
  await renderRecords();
}

async function doSearch(){
  const q=document.getElementById('searchIn').value.trim().toLowerCase();
  if(!q){log('Enter search term.','warn');return;}
  log(`🔍 "${q}"`, 'search');
  const recs=await getRecs();
  const hits=recs.filter(r=>{
    const blob=JSON.stringify(r).toLowerCase();
    const nq=q.replace(/[၀-၉]/g,d=>'၀၁၂၃၄၅၆၇၈၉'.indexOf(d).toString());
    return blob.includes(q)||blob.includes(nq);
  });
  if(!hits.length){log(`No results for "${q}"`, 'warn');return;}
  log(`Found ${hits.length} result(s):`, 'search');
  const b=document.getElementById('sysLog');
  hits.slice(0,4).forEach(r=>{
    const el=document.createElement('div');
    el.className='sr-card';
    const fields=r.fields?Object.entries(r.fields).slice(0,3).map(([k,v])=>`${k}: ${v}`).join(' · '):'';
    el.innerHTML=`<div class="sr-title">${r.icon||'📋'} ${r.title} <span style="opacity:.5">[${r.table}]</span></div><div class="sr-detail">${fields}</div>`;
    b.appendChild(el);b.scrollTop=b.scrollHeight;
  });
  if(hits.length>4) log(`…+${hits.length-4} more`, 'info');
}

async function renderRecords(){
  const recs=await getRecs();
  const list=document.getElementById('recList');
  if(!recs.length){
    list.innerHTML='<div class="empty-state"><div class="e-icon">📭</div>No records yet. Start with AI Input.</div>';
    return;
  }
  list.innerHTML=recs.slice(0,30).map(r=>{
    const fields=r.fields?Object.values(r.fields).filter(Boolean).slice(0,3).join(' · '):'';
    const t=new Date(r.timestamp);
    const dt=t.toLocaleDateString('en-GB',{day:'2-digit',month:'short'})+' '+t.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'});
    return `<div class="rec-row">
      <div class="rec-ico">${r.icon||'📋'}</div>
      <div class="rec-content">
        <div class="rec-title">${r.title||'Record'}</div>
        <div class="rec-meta">${fields}</div>
      </div>
      <span class="rec-time">${dt}</span>
      <button class="rec-del" onclick="delRec(${r.id})">✕</button>
    </div>`;
  }).join('');
}

async function delRec(id){
  const recs=await getRecs();
  await setRecs(recs.filter(r=>r.id!==id));
  log(`Deleted record ${id}`,'warn');
  await renderRecords();
}

function updateStats(){
  const r=recordsCache;
  document.getElementById('st-all').textContent=r.length;
  document.getElementById('st-rent').textContent=r.filter(x=>x.category==='rental').length;
  document.getElementById('st-sale').textContent=r.filter(x=>x.category==='sale').length;
  document.getElementById('st-cli').textContent=r.filter(x=>x.category==='client').length;
}

async function exportCSV(){
  const r=await getRecs();
  if(!r.length){log('No data.','warn');return;}
  const h=['ID','Date','Category','Table','Title','Summary','Phone','Fields'];
  const rows=r.map(x=>[
    x.id,x.timestamp?.slice(0,10)||'',x.category,x.table,x.title,x.summary||'',
    x.normalized_phone||'',
    x.fields?Object.entries(x.fields).map(([k,v])=>`${k}:${v}`).join('; '):''
  ].map(v=>`"${(v||'').toString().replace(/"/g,"'")}"` ).join(','));
  const csv=[h.join(','),...rows].join('\n');
  dl('ko_pyae_records.csv','data:text/csv;charset=utf-8,'+encodeURIComponent(csv));
  log('CSV exported.','ok');
}
async function exportJSON(){
  const r=await getRecs();
  if(!r.length){log('No data.','warn');return;}
  dl('ko_pyae_backup.json','data:application/json;charset=utf-8,'+encodeURIComponent(JSON.stringify(r,null,2)));
  log('JSON backup exported.','ok');
}
function dl(name,href){
  const a=document.createElement('a');a.href=href;a.download=name;
  document.body.appendChild(a);a.click();document.body.removeChild(a);
}
async function nukeAll(){
  if(!confirm('Delete ALL Ko Pyae records? Cannot be undone.'))return;
  await setRecs([]);
  await renderRecords();
  log('All records deleted.','warn');
}

(async function init(){
  await getRecs();
  updateStats();
  await renderRecords();
})();
</script>
</body>
</html>
