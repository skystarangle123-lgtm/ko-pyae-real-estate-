<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Ko Pyae Real Estate – AI Smart CRM</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --royal:#0A1628;
  --royal-mid:#112240;
  --royal-light:#1B3A6B;
  --royal-rim:#1E4D8C;
  --gold:#C9A84C;
  --gold-bright:#E2C06A;
  --gold-pale:#F5E9C8;
  --gold-dim:#8A6A28;
  --cream:#FAF8F3;
  --text-on-dark:#E8DFC8;
  --muted-on-dark:#8899AA;
  --white:#FFFFFF;
  --border-gold:rgba(201,168,76,0.35);
  --border-gold-bright:rgba(201,168,76,0.7);
}

html{scroll-behavior:smooth}
body{
  font-family:'Inter',sans-serif;
  background:var(--royal);
  color:var(--text-on-dark);
  min-height:100vh;
  overflow-x:hidden;
}

/* ── DECORATIVE CORNER MARKS ── */
.corner-mark{
  position:absolute;width:18px;height:18px;
  border-color:var(--gold);border-style:solid;
  opacity:.7;
}
.corner-mark.tl{top:0;left:0;border-width:2px 0 0 2px;}
.corner-mark.tr{top:0;right:0;border-width:2px 2px 0 0;}
.corner-mark.bl{bottom:0;left:0;border-width:0 0 2px 2px;}
.corner-mark.br{bottom:0;right:0;border-width:0 2px 2px 0;}

/* ── HEADER / HERO ── */
.hero{
  position:relative;
  background:linear-gradient(160deg,#0A1628 0%,#112240 50%,#0D1F3C 100%);
  border-bottom:1px solid var(--border-gold);
  padding:0;
  overflow:hidden;
}

/* Gold architectural line motif — the signature element */
.hero-lines{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
}
.hero-lines svg{position:absolute;width:100%;height:100%;opacity:.12;}

.hero-inner{
  position:relative;
  max-width:960px;margin:0 auto;
  padding:48px 32px 40px;
  display:flex;align-items:center;gap:40px;
}

/* Crown logo mark */
.brand-mark{
  flex-shrink:0;
  width:80px;height:80px;
  border:2px solid var(--gold);
  border-radius:4px;
  display:flex;align-items:center;justify-content:center;
  position:relative;
  background:rgba(201,168,76,0.06);
}
.brand-mark::before{
  content:'';
  position:absolute;inset:-5px;
  border:1px solid var(--border-gold);
  border-radius:6px;
}
.brand-icon{font-size:2.2rem;line-height:1;}

.brand-text{flex:1;}
.brand-eyebrow{
  font-family:'JetBrains Mono',monospace;
  font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:6px;opacity:.8;
}
.brand-name{
  font-family:'Cormorant Garamond',serif;
  font-size:2.6rem;font-weight:700;
  color:var(--white);
  line-height:1.05;letter-spacing:-0.01em;
}
.brand-name span{color:var(--gold);}
.brand-sub{
  font-size:0.78rem;color:var(--muted-on-dark);
  margin-top:6px;letter-spacing:0.03em;
}

/* Contact pills in header */
.contact-cluster{
  flex-shrink:0;
  display:flex;flex-direction:column;gap:8px;
  align-items:flex-end;
}
.contact-pill{
  display:flex;align-items:center;gap:8px;
  background:rgba(201,168,76,0.08);
  border:1px solid var(--border-gold);
  border-radius:6px;
  padding:8px 14px;
  font-family:'JetBrains Mono',monospace;
  font-size:0.82rem;color:var(--gold-bright);
  letter-spacing:0.04em;
  transition:all .2s;
  white-space:nowrap;
}
.contact-pill:hover{background:rgba(201,168,76,0.15);border-color:var(--gold);}
.contact-pill .ph-icon{font-size:0.9rem;opacity:.7;}

/* AI badge */
.ai-strip{
  background:rgba(10,22,40,0.8);
  border-top:1px solid var(--border-gold);
  border-bottom:1px solid var(--border-gold);
  padding:8px 32px;
  display:flex;align-items:center;gap:16px;
  font-size:0.72rem;
  color:var(--muted-on-dark);
  font-family:'JetBrains Mono',monospace;
  letter-spacing:0.05em;
}
.ai-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--gold);
  box-shadow:0 0 8px var(--gold);
  animation:glow 2s ease-in-out infinite;
}
@keyframes glow{0%,100%{opacity:1;box-shadow:0 0 6px var(--gold)}50%{opacity:.4;box-shadow:0 0 2px var(--gold)}}
.ai-tag{
  background:rgba(201,168,76,0.12);
  border:1px solid var(--border-gold);
  color:var(--gold);
  padding:2px 10px;border-radius:20px;
  font-size:0.65rem;font-weight:600;letter-spacing:0.1em;
}

/* ── TABS ── */
.tabs-bar{
  max-width:960px;margin:0 auto;
  display:flex;gap:0;
  padding:0 32px;
  border-bottom:1px solid var(--border-gold);
}
.tab{
  padding:14px 22px;
  font-size:0.82rem;font-weight:500;letter-spacing:0.04em;
  color:var(--muted-on-dark);
  cursor:pointer;border:none;background:transparent;
  border-bottom:2px solid transparent;margin-bottom:-1px;
  transition:all .2s;
  font-family:'Inter',sans-serif;
}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab:hover:not(.active){color:var(--text-on-dark);}

/* ── MAIN CONTENT ── */
.main{max-width:960px;margin:0 auto;padding:28px 32px;}
.panel{display:none;}
.panel.active{display:block;}

/* ── GOLD BOX — the signature UI element ── */
.gold-box{
  position:relative;
  background:linear-gradient(135deg,rgba(201,168,76,0.05) 0%,rgba(201,168,76,0.02) 100%);
  border:1px solid var(--border-gold-bright);
  border-radius:10px;
  padding:24px;
  margin-bottom:20px;
}
.gold-box::before{
  content:'';
  position:absolute;top:-1px;left:24px;right:24px;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  border-radius:0 0 2px 2px;
}
/* Corner ornaments */
.gold-box .corner-mark{position:absolute;}

.box-label{
  font-family:'Cormorant Garamond',serif;
  font-size:0.72rem;font-weight:600;
  letter-spacing:0.18em;text-transform:uppercase;
  color:var(--gold);margin-bottom:14px;opacity:.85;
  display:flex;align-items:center;gap:8px;
}
.box-label::after{
  content:'';flex:1;height:1px;
  background:linear-gradient(90deg,var(--border-gold),transparent);
}

/* ── INPUT AREA ── */
.data-textarea{
  width:100%;
  background:rgba(10,22,40,0.6);
  border:1px solid rgba(201,168,76,0.2);
  border-radius:8px;
  padding:14px 16px;
  font-family:'Inter',sans-serif;
  font-size:0.93rem;
  color:var(--text-on-dark);
  resize:none;min-height:120px;
  outline:none;line-height:1.65;
  transition:border-color .2s;
}
.data-textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.08);}
.data-textarea::placeholder{color:rgba(136,153,170,0.6);}

/* Example chips */
.chip-row{display:flex;flex-wrap:wrap;gap:7px;margin:12px 0;}
.chip{
  background:rgba(201,168,76,0.06);
  border:1px solid rgba(201,168,76,0.25);
  border-radius:5px;padding:5px 11px;
  font-size:0.73rem;color:var(--muted-on-dark);
  cursor:pointer;font-family:'JetBrains Mono',monospace;
  transition:all .15s;letter-spacing:0.02em;
}
.chip:hover{border-color:var(--gold);color:var(--gold-bright);}

/* ── BUTTONS ── */
.btn-row{display:flex;gap:10px;margin-top:14px;}
.btn{
  padding:10px 24px;
  border:none;border-radius:7px;
  font-family:'Inter',sans-serif;font-weight:600;
  font-size:0.87rem;cursor:pointer;
  transition:all .2s;letter-spacing:0.02em;
  display:inline-flex;align-items:center;gap:7px;
}
.btn-gold{
  background:linear-gradient(135deg,var(--gold) 0%,var(--gold-bright) 100%);
  color:var(--royal);
  box-shadow:0 2px 12px rgba(201,168,76,0.3);
}
.btn-gold:hover{box-shadow:0 4px 20px rgba(201,168,76,0.45);transform:translateY(-1px);}
.btn-gold:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.btn-ghost{
  background:transparent;
  border:1px solid rgba(201,168,76,0.3);
  color:var(--muted-on-dark);
}
.btn-ghost:hover{border-color:var(--gold);color:var(--text-on-dark);}
.btn-sm{padding:6px 14px;font-size:0.78rem;}

/* ── AI THINKING ── */
.thinking-box{
  display:none;
  background:rgba(10,22,40,0.7);
  border:1px solid rgba(201,168,76,0.2);
  border-radius:8px;padding:14px 16px;margin-bottom:16px;
}
.thinking-box.active{display:block;}
.th-header{
  display:flex;align-items:center;gap:8px;
  font-size:0.78rem;color:var(--gold);font-weight:600;
  margin-bottom:10px;letter-spacing:0.04em;
}
.dots span{
  display:inline-block;width:4px;height:4px;border-radius:50%;
  background:var(--gold);margin:0 2px;
  animation:bd .7s infinite;
}
.dots span:nth-child(2){animation-delay:.15s;}
.dots span:nth-child(3){animation-delay:.3s;}
@keyframes bd{0%,80%,100%{transform:scale(1)}40%{transform:scale(1.6)}}
.th-steps{
  font-family:'JetBrains Mono',monospace;
  font-size:0.76rem;color:var(--muted-on-dark);line-height:1.9;
}
.step{opacity:0;transform:translateX(-6px);transition:all .3s;}
.step.show{opacity:1;transform:none;}
.step.ok{color:#4CAF8A;}
.step.ai{color:var(--gold);}
.step.map{color:#7BA7D4;}

/* ── RESULT CARD ── */
.result-card{
  display:none;
  border:1px solid var(--border-gold-bright);
  border-radius:10px;overflow:hidden;margin-bottom:16px;
}
.result-card.show{display:block;}
.rc-head{
  background:linear-gradient(90deg,rgba(201,168,76,0.12),rgba(201,168,76,0.04));
  border-bottom:1px solid var(--border-gold);
  padding:12px 18px;
  display:flex;align-items:center;justify-content:space-between;
}
.rc-title-row{display:flex;align-items:center;gap:10px;}
.rc-title{
  font-family:'Cormorant Garamond',serif;
  font-size:1.1rem;font-weight:600;color:var(--white);
}
.cat-pill{
  padding:3px 10px;border-radius:5px;
  font-size:0.68rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
}
.cat-rental{background:rgba(63,185,80,.15);color:#50C878;border:1px solid rgba(63,185,80,.3);}
.cat-sale{background:rgba(201,168,76,.15);color:var(--gold);border:1px solid var(--border-gold);}
.cat-client{background:rgba(100,149,237,.15);color:#89B4FA;border:1px solid rgba(100,149,237,.3);}
.cat-schedule{background:rgba(188,140,255,.15);color:#CBA4FF;border:1px solid rgba(188,140,255,.3);}
.rc-table-tag{
  font-family:'JetBrains Mono',monospace;
  font-size:0.72rem;color:var(--muted-on-dark);
}

.rc-body{padding:16px 18px;}
.field-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.field-item{
  background:rgba(10,22,40,0.5);
  border:1px solid rgba(201,168,76,0.15);
  border-radius:7px;padding:9px 12px;
}
.field-k{
  font-size:0.65rem;color:var(--gold-dim);
  font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:3px;
}
.field-v{
  font-size:0.86rem;color:var(--text-on-dark);
  font-family:'JetBrains Mono',monospace;
}
.field-v.hi{color:var(--gold-bright);}

.conf-row{
  display:flex;align-items:center;gap:10px;
  margin-top:12px;font-size:0.75rem;color:var(--muted-on-dark);
}
.conf-track{flex:1;height:3px;background:rgba(201,168,76,0.1);border-radius:2px;}
.conf-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold-dim),var(--gold-bright));transition:width 1.2s ease;}

.rc-actions{
  padding:12px 18px;border-top:1px solid var(--border-gold);
  display:flex;gap:8px;background:rgba(10,22,40,0.3);
}

/* ── LAYOUT (input left, log right) ── */
.two-col{display:grid;grid-template-columns:1fr 340px;gap:20px;}

/* ── SYSTEM LOG ── */
.log-panel{
  position:relative;
  border:1px solid var(--border-gold);
  border-radius:10px;overflow:hidden;
  display:flex;flex-direction:column;
  max-height:600px;
}
.log-panel::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.log-head{
  padding:11px 16px;
  border-bottom:1px solid var(--border-gold);
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(201,168,76,0.05);
}
.log-title{
  font-family:'JetBrains Mono',monospace;
  font-size:0.72rem;color:var(--gold);letter-spacing:0.1em;
}
.log-clear{
  background:transparent;border:none;
  font-family:'JetBrains Mono',monospace;
  font-size:0.68rem;color:var(--muted-on-dark);cursor:pointer;
  transition:color .15s;
}
.log-clear:hover{color:var(--gold);}

.search-row{
  display:flex;gap:7px;padding:10px 12px;
  border-bottom:1px solid var(--border-gold);
}
.search-in{
  flex:1;background:rgba(10,22,40,0.7);
  border:1px solid rgba(201,168,76,0.2);border-radius:6px;
  padding:7px 11px;font-family:'Inter',sans-serif;
  font-size:0.8rem;color:var(--text-on-dark);outline:none;
  transition:border-color .2s;
}
.search-in:focus{border-color:var(--gold);}
.search-in::placeholder{color:var(--muted-on-dark);opacity:.5;}
.search-go{
  padding:7px 13px;background:rgba(201,168,76,0.1);
  border:1px solid var(--border-gold);border-radius:6px;
  color:var(--gold);font-size:0.8rem;cursor:pointer;
  transition:all .15s;font-weight:600;
}
.search-go:hover{background:rgba(201,168,76,0.2);}

.log-body{flex:1;overflow-y:auto;padding:10px 12px;display:flex;flex-direction:column;gap:5px;}
.log-body::-webkit-scrollbar{width:3px;}
.log-body::-webkit-scrollbar-track{background:transparent;}
.log-body::-webkit-scrollbar-thumb{background:var(--gold-dim);border-radius:2px;}

.le{
  font-family:'JetBrains Mono',monospace;
  font-size:0.72rem;padding:6px 9px;border-radius:5px;
  border-left:2px solid;line-height:1.5;
  animation:fadeUp .25s ease;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
.le-info{background:rgba(139,148,158,.04);border-color:rgba(139,148,158,.3);color:var(--muted-on-dark);}
.le-ok{background:rgba(63,185,80,.04);border-color:rgba(63,185,80,.4);color:#50C878;}
.le-ai{background:rgba(201,168,76,.04);border-color:rgba(201,168,76,.4);color:var(--gold-bright);}
.le-warn{background:rgba(201,168,76,.06);border-color:var(--gold-dim);color:var(--gold);}
.le-err{background:rgba(248,81,73,.04);border-color:rgba(248,81,73,.4);color:#F87171;}
.le-search{background:rgba(100,149,237,.04);border-color:rgba(100,149,237,.4);color:#89B4FA;}
.le-time{opacity:.4;margin-right:7px;font-size:0.65rem;}

.sr-card{
  background:rgba(201,168,76,0.05);
  border:1px solid rgba(201,168,76,0.2);
  border-radius:7px;padding:9px 11px;
  font-size:0.72rem;
}
.sr-title{color:var(--gold);font-weight:600;margin-bottom:3px;}
.sr-detail{color:var(--muted-on-dark);line-height:1.7;}

/* ── STATS FOOTER ── */
.stats-row{
  display:grid;grid-template-columns:repeat(4,1fr);gap:12px;
  margin-top:20px;
}
.stat-card{
  position:relative;
  background:linear-gradient(135deg,rgba(201,168,76,0.06),rgba(201,168,76,0.02));
  border:1px solid var(--border-gold);
  border-radius:9px;padding:16px;text-align:center;
  overflow:hidden;
}
.stat-card::after{
  content:'';position:absolute;top:0;left:25%;right:25%;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.stat-n{
  font-family:'Cormorant Garamond',serif;
  font-size:2rem;font-weight:700;color:var(--gold-bright);
}
.stat-l{font-size:0.68rem;color:var(--muted-on-dark);letter-spacing:0.08em;text-transform:uppercase;margin-top:2px;}

/* ── RECORDS LIST ── */
.records-section{margin-top:24px;}
.rec-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.section-title-gold{
  font-family:'Cormorant Garamond',serif;
  font-size:1rem;font-weight:600;color:var(--gold);
  letter-spacing:0.05em;
  display:flex;align-items:center;gap:10px;
}
.section-title-gold::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border-gold),transparent);}

.records-list{display:flex;flex-direction:column;gap:8px;}
.rec-row{
  display:flex;align-items:center;gap:12px;
  background:rgba(201,168,76,0.03);
  border:1px solid rgba(201,168,76,0.15);
  border-radius:9px;padding:12px 14px;
  transition:border-color .2s;
}
.rec-row:hover{border-color:var(--border-gold);}
.rec-ico{
  width:38px;height:38px;border-radius:7px;border:1px solid var(--border-gold);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
  background:rgba(201,168,76,0.05);
}
.rec-content{flex:1;min-width:0;}
.rec-title{font-weight:600;font-size:0.87rem;color:var(--text-on-dark);}
.rec-meta{font-size:0.73rem;color:var(--muted-on-dark);font-family:'JetBrains Mono',monospace;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.rec-time{font-size:0.68rem;color:var(--muted-on-dark);flex-shrink:0;}
.rec-del{
  background:transparent;border:none;
  color:rgba(139,148,158,.4);cursor:pointer;
  padding:3px 7px;border-radius:4px;font-size:0.75rem;
  transition:all .15s;flex-shrink:0;
}
.rec-del:hover{color:#F87171;background:rgba(248,81,73,.08);}

.empty-state{
  text-align:center;padding:40px;
  color:var(--muted-on-dark);font-size:0.88rem;
}
.empty-state .e-icon{font-size:2.5rem;margin-bottom:8px;opacity:.5;}

/* ── EXPORT PANEL ── */
.export-box{
  border:1px solid var(--border-gold);border-radius:10px;overflow:hidden;margin-bottom:20px;
}
.eb-head{
  padding:14px 20px;
  background:rgba(201,168,76,0.06);
  border-bottom:1px solid var(--border-gold);
  font-family:'Cormorant Garamond',serif;font-size:1rem;
  font-weight:600;color:var(--gold);
}
.eb-body{padding:20px;}
.eb-body p{font-size:0.88rem;color:var(--muted-on-dark);margin-bottom:16px;line-height:1.6;}
.danger-row{
  border-top:1px solid rgba(248,81,73,.2);
  padding-top:16px;margin-top:16px;
}
.btn-danger{
  padding:9px 20px;background:transparent;
  border:1px solid rgba(248,81,73,.4);border-radius:7px;
  color:#F87171;font-family:'Inter',sans-serif;font-weight:600;
  font-size:0.85rem;cursor:pointer;transition:all .2s;
}
.btn-danger:hover{background:rgba(248,81,73,.08);border-color:#F87171;}

@media(max-width:700px){
  .two-col{grid-template-columns:1fr;}
  .field-grid{grid-template-columns:1fr;}
  .stats-row{grid-template-columns:1fr 1fr;}
  .hero-inner{flex-direction:column;gap:20px;padding:28px 20px;}
  .contact-cluster{align-items:flex-start;}
  .main{padding:20px 16px;}
  .brand-name{font-size:2rem;}
}
</style>
</head>
<body>

<!-- ══════════ HERO ══════════ -->
<div class="hero">
  <div class="hero-lines">
    <svg viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid slice">
      <!-- Architectural grid lines -->
      <line x1="0" y1="40" x2="1000" y2="40" stroke="#C9A84C" stroke-width="0.5"/>
      <line x1="0" y1="160" x2="1000" y2="160" stroke="#C9A84C" stroke-width="0.5"/>
      <line x1="120" y1="0" x2="120" y2="200" stroke="#C9A84C" stroke-width="0.5"/>
      <line x1="880" y1="0" x2="880" y2="200" stroke="#C9A84C" stroke-width="0.5"/>
      <!-- Diagonal accent -->
